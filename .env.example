OTN_ADMIN_TOKEN=change-this-admin-token
OTN_SECRET_KEY=change-this-long-random-secret-key
OTN_DATABASE_PATH=/data/own-newsletter.sqlite
OTN_FEEDS_DIR=/data/feeds
OTN_BACKEND_PORT=8000
OTN_FRONTEND_PORT=8080
OTN_PUBLIC_ORIGIN=http://localhost:8080
OTN_COOKIE_SECURE=false
OTN_SESSION_DAYS=30
OTN_SCHEDULER_ENABLED=true
OTN_SCHEDULER_TICK_SECONDS=60
OTN_IMAP_TIMEOUT_SECONDS=30
OTN_LOG_LEVEL=INFO
